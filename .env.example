# =============================================================================
# VoltWise — Docker Environment Variables
#
# Copy this file to .env and fill in your values before running:
#   cp .env.example .env
#   docker-compose up --build
#
# IMPORTANT: Never commit .env to version control.
# =============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=voltwise
POSTGRES_USER=voltwise
POSTGRES_PASSWORD=voltwise_change_me_in_production

# ── Django (voltwise-cloud) ────────────────────────────────────────────────────
# Generate a strong secret key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-very-long-random-string

# Use 'config.settings.dev'  for local development (DEBUG=True, relaxed CORS)
# Use 'config.settings.prod' for production (requires SSL and ALLOWED_HOSTS)
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database — DB_HOST is overridden by docker-compose to 'db' automatically
DB_NAME=voltwise
DB_USER=voltwise
DB_PASSWORD=voltwise_change_me_in_production
DB_HOST=db
DB_PORT=5432

# Redis — points to the redis container
REDIS_URL=redis://redis:6379/0

# Allowed hosts (comma-separated) — required for config.settings.prod
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS allowed origins (comma-separated) — required for config.settings.prod
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Internal API key shared between services
INTERNAL_API_KEY=change-me-in-production

# ── voltwise-ocpp ──────────────────────────────────────────────────────────────
OCPP_ADDR=:8080
OCPP_LOG=info

# ── Gunicorn tuning (optional) ─────────────────────────────────────────────────
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120
# GUNICORN_LOG_LEVEL=info
